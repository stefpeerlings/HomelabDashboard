# Optionele omgevingsvariabelen (systemd Environment= of export)
# Kopieer naar /etc/homelab-dashboard/env en source in systemd unit.

HOMELAB_APP_ROOT=/opt/homelab-dashboard
HOMELAB_CREDENTIALS_DIR=/root/.homelab-db/credentials
HOMELAB_PUBLIC_URL=http://dashboard.lan:8765/

# Eerste admin-wachtwoord (leeg = willekeurig gegenereerd)
# HOMELAB_BOOTSTRAP_PASSWORD=

# Status-blok bovenaan (JSON-array of shell-woorden)
# HOMELAB_STATUS_COMMAND='["/usr/local/bin/mijn-status.sh","check"]'

# PBS / Proxmox SSH (pas aan jouw omgeving)
HOMELAB_PBS_SSH=root@pbs
HOMELAB_PBS_HOSTS=pbs
HOMELAB_PBS_KEY=/root/.ssh/pbs_key
HOMELAB_PROXMOX_KEY=/root/.ssh/id_ed25519
HOMELAB_LOCAL_HOSTS=localhost,127.0.0.1,proxmox.lan

# MariaDB grant subnet bij setup-mariadb.sh
# HOMELAB_DB_HOST_PATTERN=192.168.%